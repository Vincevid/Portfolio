---
// layouts/PortfolioLayout.astro
// Main layout for portfolio pages

import Navigation from '../components/Navigation.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Vincent Vidaurri</title>
  {description && <meta name="description" content={description} />}

  <!-- Fonts - Clash Display & Satoshi -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@400,500,700&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Cloud Texture Background -->
  <div class="cloud-background"></div>

  <!-- Dark Overlay to tone down brightness -->
  <div class="background-overlay"></div>

  <div class="layout">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
      <Navigation />
    </aside>

    <!-- Main Content -->
    <main class="content">
      <slot />
    </main>
  </div>
</body>
</html>

<style>
  /* ========================================
     Cloud Texture Background
     ======================================== */

  .cloud-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background-image: url('/cloud.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.3;
    mix-blend-mode: screen;
    animation: cloudDrift 20s ease-in-out infinite alternate;
  }

  @keyframes cloudDrift {
    0% {
      transform: scale(1) translate(0, 0);
    }
    100% {
      transform: scale(1.2) translate(2.5%, 2.5%);
    }
  }

  /* Dark overlay to reduce cloud brightness */
  .background-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background-color: rgba(26, 26, 26, 0.7);
    pointer-events: none;
  }

  .layout {
    display: flex;
    min-height: 100vh;
    position: relative;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    padding: 40px 40px;
    z-index: 100;
  }

  .content {
    margin-left: var(--sidebar-width);
    flex: 1;
    padding: 3rem 4rem;
  }

  /* Responsive layout */
  @media (max-width: 768px) {
    .layout {
      flex-direction: column;
    }

    .sidebar {
      position: relative;
      height: auto;
      padding: 1.5rem;
    }

    .content {
      margin-left: 0;
      padding: 2rem 1.5rem;
    }
  }

  /* Accessibility - Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .cloud-background {
      animation: none;
    }
  }

</style>
