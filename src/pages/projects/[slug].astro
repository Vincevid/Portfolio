---
import { getCollection } from 'astro:content';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await project.render();
const { title, description, role, company, duration, tags, technologies, liveUrl, githubUrl, heroImage, date } = project.data;
const hasToc = headings.some((h) => h.depth === 2 || h.depth === 3);
---

<PortfolioLayout title={title} description={description}>
  <div class:list={['project-layout', { 'project-layout--with-toc': hasToc }]}>
    <article class="project-detail">
      <!-- Hero Section -->
      <div class="project-hero">
        <div class="hero-image-wrapper">
          <img src={heroImage} alt={title} class="hero-image" />
        </div>
      </div>

      <!-- Project Header -->
      <header class="project-header">
        <h1 class="project-title">{title}</h1>
        <p class="project-description">{description}</p>

        <!-- Meta Information -->
        <div class="project-meta">
          <div class="meta-item">
            <span class="meta-label">Role</span>
            <span class="meta-value">{role}</span>
          </div>
          {company && (
            <div class="meta-item">
              <span class="meta-label">Company</span>
              <span class="meta-value">{company}</span>
            </div>
          )}
          {duration && (
            <div class="meta-item">
              <span class="meta-label">Duration</span>
              <span class="meta-value">{duration}</span>
            </div>
          )}
          <div class="meta-item">
            <span class="meta-label">Date</span>
            <span class="meta-value">{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
          </div>
        </div>

        <!-- Tags -->
        {tags && tags.length > 0 && (
          <div class="project-tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}

        <!-- Technologies -->
        {technologies && technologies.length > 0 && (
          <div class="project-technologies">
            <h4>Technologies Used</h4>
            <div class="tech-list">
              {technologies.map((tech) => (
                <span class="tech-badge">{tech}</span>
              ))}
            </div>
          </div>
        )}

        <!-- Links -->
        <div class="project-links">
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="project-link">
              View Live Site →
            </a>
          )}
          {githubUrl && (
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="project-link">
              View on GitHub →
            </a>
          )}
        </div>
      </header>

      <!-- Project Content (MDX) -->
      <div class="project-content">
        <Content />
      </div>
    </article>

    {hasToc && (
      <aside class="toc-column">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</PortfolioLayout>

<style>
  /* Layout */
  .project-layout {
    display: grid;
    grid-template-columns: 1fr;
  }

  .toc-column {
    display: none;
  }

  @media (min-width: 1200px) {
    .project-layout--with-toc {
      grid-template-columns: 1fr 220px;
      gap: var(--spacing-2xl);
    }

    .toc-column {
      display: block;
    }
  }

  .project-detail {
    min-width: 0;
    max-width: 800px;
  }

  /* Hero Section */
  .project-hero {
    margin-bottom: var(--spacing-2xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero-image-wrapper {
    aspect-ratio: 16 / 9;
    background-color: var(--color-bg-card);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Project Header */
  .project-header {
    margin-bottom: var(--spacing-3xl);
  }

  .project-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .project-description {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-xl);
    line-height: 1.6;
  }

  /* Meta Information */
  .project-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background-color: var(--color-bg-card);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-xl);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .meta-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .meta-value {
    font-size: var(--font-size-base);
    color: var(--color-text);
    font-weight: 500;
  }

  /* Tags */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
  }

  .tag {
    background-color: var(--color-bg-card);
    color: var(--color-text-secondary);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    border: 1px solid var(--color-border);
  }

  /* Technologies */
  .project-technologies {
    margin-bottom: var(--spacing-xl);
  }

  .project-technologies h4 {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    font-weight: 500;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .tech-badge {
    background-color: var(--color-border);
    color: var(--color-text);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-family: 'Monaco', monospace;
  }

  /* Project Links */
  .project-links {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm) var(--spacing-lg);
    background-color: var(--color-bg-card);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: 500;
    transition: all var(--transition-base);
  }

  .project-link:hover {
    background-color: var(--color-border);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* Project Content (MDX) */
  .project-content {
    line-height: 1.8;
  }

  .project-content :global(h2) {
    font-size: var(--font-size-2xl);
    margin-top: var(--spacing-3xl);
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: 1.5rem;
  }

  .project-content :global(h3) {
    font-size: var(--font-size-xl);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
    scroll-margin-top: 1.5rem;
  }

  .project-content :global(p) {
    margin-bottom: var(--spacing-lg);
    color: var(--color-text-secondary);
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-bottom: var(--spacing-lg);
    padding-left: var(--spacing-xl);
  }

  .project-content :global(li) {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-secondary);
  }

  .project-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .project-content :global(code) {
    background-color: var(--color-bg-card);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .project-content :global(pre) {
    background-color: var(--color-bg-card);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--spacing-xl);
    border: 1px solid var(--color-border);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .project-title {
      font-size: var(--font-size-3xl);
    }

    .project-description {
      font-size: var(--font-size-lg);
    }

    .project-meta {
      grid-template-columns: 1fr;
    }

    .project-links {
      flex-direction: column;
    }
  }
</style>
