---
import { getCollection } from 'astro:content';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PortfolioLayout
  title="Projects"
  description="Browse all projects by Vincent Vidaurri"
>
  <div class="projects-page">
    <header class="page-header">
      <div class="header-label">
        <span class="label-text">Work</span>
        <div class="label-line"></div>
      </div>
      <h1>All Projects</h1>
      <p class="subtitle">
        A collection of personal projects and design experimentation.
      </p>
    </header>

    <div class="projects-grid">
      {sortedProjects.map((project, index) => (
        <a
          href={`/projects/${project.slug}`}
          class="project-card"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="card-image">
            <video src={project.data.heroImage} autoplay loop muted playsinline />
          </div>
          <div class="card-content">
            <h2 class="card-title">{project.data.title}</h2>
            <p class="card-description">{project.data.description}</p>

            <div class="card-meta">
              <span class="card-role">{project.data.role}</span>
              {project.data.company && (
                <>
                  <span class="separator">•</span>
                  <span class="card-company">{project.data.company}</span>
                </>
              )}
            </div>

            <div class="card-tags">
              {project.data.tags.slice(0, 3).map((tag) => (
                <span class="card-tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</PortfolioLayout>

<style>
  .projects-page {
    max-width: 1200px;
  }

  /* ── Page Header ───────────────────────────── */
  .page-header {
    margin-bottom: var(--spacing-3xl);
    animation: fadeUp 0.8s ease-out 0.1s both;
  }

  .header-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .label-text {
    font-family: 'Courier New', monospace;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    white-space: nowrap;
    font-weight: 600;
  }

  .label-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(65, 196, 66, 0.5), transparent);
  }

  .page-header h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--spacing-sm);
  }

  .subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 700px;
    line-height: 1.7;
  }

  /* ── Projects Grid ─────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-2xl);
    animation: fadeUp 0.8s ease-out 0.25s both;
  }

  /* ── Project Card ──────────────────────────── */
  .project-card {
    background: linear-gradient(
      135deg,
      rgba(45, 45, 45, 0.4),
      rgba(35, 35, 35, 0.6)
    );
    border: 1px solid rgba(65, 196, 66, 0.15);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    position: relative;
    opacity: 0;
    animation: fadeUp 0.6s ease-out forwards;
  }

  /* Top accent bar — hidden by default, revealed on hover */
  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-brand), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: 1;
  }

  .project-card:hover {
    border-color: rgba(65, 196, 66, 0.4);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(65, 196, 66, 0.15);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  /* ── Card Image / Video ────────────────────── */
  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-bg-elevated);
    overflow: hidden;
  }

  .card-image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-card:hover .card-image video {
    transform: scale(1.05);
  }

  /* ── Card Content ──────────────────────────── */
  .card-content {
    padding: var(--spacing-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-family-display);
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .card-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
    flex: 1;
  }

  /* ── Card Meta (role / company) ────────────── */
  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
  }

  .card-role,
  .card-company {
    font-family: 'Courier New', monospace;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(65, 196, 66, 0.7);
    font-weight: 600;
  }

  .separator {
    color: var(--color-border);
    font-size: var(--font-size-xs);
  }

  /* ── Tags — glassmorphism chips ────────────── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .card-tag {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    background-color: rgba(45, 45, 45, 0.8);
    backdrop-filter: blur(10px);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-md);
    border: 1px solid rgba(65, 196, 66, 0.2);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .project-card:hover .card-tag {
    color: var(--color-text-secondary);
    border-color: rgba(65, 196, 66, 0.35);
  }

  /* ── Entrance Animation ────────────────────── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }

    .page-header h1 {
      font-size: var(--font-size-3xl);
    }
  }

  /* ── Reduced Motion ────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .page-header,
    .projects-grid,
    .project-card {
      animation: none;
      opacity: 1;
    }

    .project-card:hover {
      transform: none;
    }

    .project-card:hover .card-image video {
      transform: none;
    }
  }
</style>
