---
import { getCollection } from 'astro:content';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';

// Get all projects
const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PortfolioLayout
  title="Projects"
  description="Browse all projects by Vincent Vidaurri"
>
  <div class="projects-page">
    <header class="page-header">
      <h1>All Projects</h1>
      <p class="subtitle">
        A collection of my work across aerospace, XR technologies, and product design.
      </p>
    </header>

    <div class="projects-grid">
      {sortedProjects.map((project, index) => (
        <a
          href={`/projects/${project.slug}`}
          class="project-card"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="card-image">
            <img src={project.data.heroImage} alt={project.data.title} />
          </div>
          <div class="card-content">
            <h2 class="card-title">{project.data.title}</h2>
            <p class="card-description">{project.data.description}</p>

            <div class="card-meta">
              <span class="card-role">{project.data.role}</span>
              {project.data.company && (
                <>
                  <span class="separator">•</span>
                  <span class="card-company">{project.data.company}</span>
                </>
              )}
            </div>

            <div class="card-tags">
              {project.data.tags.slice(0, 3).map((tag) => (
                <span class="card-tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</PortfolioLayout>

<style>
  .projects-page {
    max-width: 1200px;
  }

  .page-header {
    margin-bottom: var(--spacing-3xl);
  }

  .page-header h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--spacing-sm);
  }

  .subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 700px;
    line-height: 1.7;
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-2xl);
  }

  .project-card {
    background-color: var(--color-bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-bg-elevated);
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: var(--spacing-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .card-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .separator {
    color: var(--color-border);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .card-tag {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    background-color: var(--color-bg-elevated);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }

    .page-header h1 {
      font-size: var(--font-size-3xl);
    }
  }

  /* Accessibility - Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .project-card {
      animation: none;
      opacity: 1;
    }

    .project-card:hover {
      transform: none;
    }

    .project-card:hover .card-image img {
      transform: none;
    }
  }
</style>
