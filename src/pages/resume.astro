---
import { getEntry, render } from 'astro:content';
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import ExperienceEntry from '../components/ExperienceEntry.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';

const entry = await getEntry('experience', 'experience');
if (!entry) throw new Error('experience/experience.mdx not found');
const { Content } = await render(entry);
---

<PortfolioLayout
  title="Resume"
  description="Vincent Vidaurri's professional experience in aerospace, XR, and product management"
>
  <div class="resume-layout">
    <div class="resume">
      <header class="resume-header">
        <h1>Work History</h1>
        <p class="subtitle">Product Manager & Designer specializing in aerospace and XR technologies</p>
      </header>

      <!-- Work Experience -->
      <section class="resume-section">
        <div class="section-label">
          <span class="label-text">Work Experience</span>
          <div class="label-line"></div>
        </div>
        <div class="experience-content">
          <Content components={{ ExperienceEntry }} />
        </div>
      </section>

      <!-- Skills -->
      <section class="resume-section">
        <div class="section-label">
          <span class="label-text">Skills & Expertise</span>
          <div class="label-line"></div>
        </div>

        <div class="skills-grid">
          <div class="skill-category">
            <h3>XR & Immersive Tech</h3>
            <div class="skill-tags">
              <span class="skill-tag">AR/VR</span>
              <span class="skill-tag">XR</span>
              <span class="skill-tag">Unity</span>
              <span class="skill-tag">Simulation</span>
              <span class="skill-tag">Training Systems</span>
            </div>
          </div>

          <div class="skill-category">
            <h3>Product Management</h3>
            <div class="skill-tags">
              <span class="skill-tag">Roadmap Planning</span>
              <span class="skill-tag">Stakeholder Management</span>
              <span class="skill-tag">Agile / Jira</span>
            </div>
          </div>

          <div class="skill-category">
            <h3>Design Systems</h3>
            <div class="skill-tags">
              <span class="skill-tag">Figma</span>
              <span class="skill-tag">Design Systems</span>
              <span class="skill-tag">UX</span>
              <span class="skill-tag">Prototyping</span>
            </div>
          </div>

          <div class="skill-category">
            <h3>Technical</h3>
            <div class="skill-tags">
              <span class="skill-tag">Next.js</span>
              <span class="skill-tag">Cesium.js</span>
              <span class="skill-tag">Supabase</span>
              <span class="skill-tag">Power BI</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Education -->
      <section class="resume-section">
        <div class="section-label">
          <span class="label-text">Education</span>
          <div class="label-line"></div>
        </div>
        <div class="education-item">
          <h3>Bachelors of Arts in Studio Art with a focus in Graphic Design</h3>
          <p class="institution">University of Alabama - Huntsville</p>
          <p class="duration">2007 - 2015</p>
        </div>
      </section>

    </div>

    <aside class="timeline-column">
      <ExperienceTimeline />
    </aside>
  </div>
</PortfolioLayout>

<style is:global>
  /* Layout grid — global to guarantee the rules are not lost to Astro's
     scoped-hash mechanism when the aside directly wraps a component */
  .resume-layout {
    display: grid;
    grid-template-columns: 1fr;
  }

  .timeline-column {
    display: none;
  }

  @media (min-width: 1200px) {
    .resume-layout {
      grid-template-columns: 1fr 220px;
      gap: var(--spacing-2xl);
    }
    .timeline-column {
      display: block;
    }
  }

  /* Download button — brand-green fill with clipped top-right corner + shimmer */
  .download-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--spacing-lg);
    padding: var(--spacing-md) var(--spacing-2xl);
    background-color: var(--color-brand);
    color: var(--color-bg);
    border: 1px solid var(--color-brand);
    font-family: var(--font-family-display);
    font-size: var(--font-size-base);
    font-weight: 600;
    text-decoration: none;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%);
    overflow: hidden;
    position: relative;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .download-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left var(--transition-slow);
  }

  .download-button:hover {
    box-shadow: 0 0 30px rgba(65, 196, 66, 0.5);
    transform: translateY(-2px);
  }

  .download-button:hover::before {
    left: 100%;
  }
</style>

<style>
  /* Main content column */
  .resume {
    min-width: 0;
  }

  .resume-header {
    margin-bottom: var(--spacing-3xl);
  }

  .resume-header h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--spacing-sm);
  }

  .subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
  }

  /* Sections */
  .resume-section {
    margin-bottom: var(--spacing-3xl);
  }

  /* Section label — matches [slug].astro + TableOfContents pattern */
  .section-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .label-text {
    font-family: 'Courier New', monospace;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    font-weight: 600;
    white-space: nowrap;
  }

  .label-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(65, 196, 66, 0.5), transparent);
  }

  /* MDX content global styles */
  .experience-content :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    font-family: var(--font-family-display);
    margin-bottom: var(--spacing-lg);
  }

  .experience-content :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }

  .experience-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(65, 196, 66, 0.1);
    margin: var(--spacing-md) 0;
  }

  /* Skills Grid */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-xl);
  }

  .skill-category h3 {
    font-size: var(--font-size-base);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .skill-tag {
    background-color: rgba(45, 45, 45, 0.8);
    backdrop-filter: blur(10px);
    color: var(--color-text-secondary);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    border: 1px solid rgba(65, 196, 66, 0.2);
    transition: all var(--transition-fast);
  }

  .skill-tag:hover {
    border-color: rgba(65, 196, 66, 0.5);
    color: var(--color-brand);
  }

  /* Education */
  .education-item h3 {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }

  .institution {
    font-size: var(--font-size-base);
    color: var(--color-brand);
    font-weight: 500;
    margin-bottom: var(--spacing-xs);
  }

  .duration {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
  }

  .details {
    color: var(--color-text-secondary);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Print */
  @media print {
    .resume-actions {
      display: none;
    }
  }
</style>
