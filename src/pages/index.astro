---
import { getCollection } from 'astro:content';
import PortfolioLayout from '../layouts/PortfolioLayout.astro';

// Get featured projects
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<PortfolioLayout
  title="Home"
  description="Vincent Vidaurri - Product Manager & Designer specializing in aerospace, XR, and immersive technologies"
>
  <!-- Hero Section -->
  <section class="hero">
    <h1 class="hero-title">Vincent Vidaurri</h1>
    <p class="hero-subtitle">Product Manager & Designer</p>
    <p class="hero-description">
      Building exceptional products at the intersection of aerospace, XR, and immersive technologies.
      Former NASA and Blue Origin, passionate about creating experiences that push boundaries.
    </p>
  </section>

  <!-- Featured Projects Section -->
  <section class="featured-projects">
    <h2 class="section-title">Featured Projects</h2>
    <div class="projects-grid">
      {featuredProjects.map((project, index) => (
        <a href={`/projects/${project.slug}`} class="project-card" style={`animation-delay: ${0.1 + index * 0.1}s`}>
          <div class="card-image">
            <img src={project.data.heroImage} alt={project.data.title} />
          </div>
          <div class="card-content">
            <h3 class="card-title">{project.data.title}</h3>
            <p class="card-description">{project.data.description}</p>
            <div class="card-tags">
              {project.data.tags.slice(0, 3).map((tag) => (
                <span class="card-tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Brief Bio Section -->
  <section class="bio">
    <h2 class="section-title">About Me</h2>
    <div class="bio-content">
      <p>
        With a background spanning NASA's cutting-edge research initiatives and Blue Origin's
        commercial spaceflight programs, I bring a unique perspective to product design and management.
        My expertise lies in translating complex technical requirements into intuitive, user-centered experiences.
      </p>
      <p>
        I specialize in AR/VR/XR technologies, design systems, and building products that blend
        hardware and software seamlessly. Whether it's developing IoT sensor networks for research
        facilities or creating AI-powered analysis tools, I'm driven by the challenge of solving
        meaningful problems through thoughtful design and engineering.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="cta-buttons">
      <a href="/projects" class="cta-button primary">View All Projects</a>
      <a href="/contact" class="cta-button secondary">Get in Touch</a>
    </div>
  </section>
</PortfolioLayout>

<style>
  /* ========================================
     Hero Section
     ======================================== */

  .hero {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-bottom: var(--spacing-3xl);
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title {
    font-size: var(--font-size-5xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: var(--font-size-2xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-xl);
    font-weight: 400;
  }

  .hero-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 700px;
    line-height: 1.7;
  }

  /* ========================================
     Featured Projects Section
     ======================================== */

  .featured-projects {
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-3xl);
    font-weight: 600;
    margin-bottom: var(--spacing-2xl);
    color: var(--color-text);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
  }

  .project-card {
    background-color: var(--color-bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-bg-elevated);
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: var(--spacing-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .card-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .card-tag {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    background-color: var(--color-bg-elevated);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  /* ========================================
     Bio Section
     ======================================== */

  .bio {
    margin-bottom: var(--spacing-3xl);
  }

  .bio-content {
    max-width: 800px;
  }

  .bio-content p {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }

  /* ========================================
     CTA Section
     ======================================== */

  .cta {
    margin-bottom: var(--spacing-3xl);
    padding: var(--spacing-3xl) 0;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md) var(--spacing-2xl);
    font-size: var(--font-size-lg);
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .cta-button.primary {
    background-color: var(--color-text);
    color: var(--color-bg);
    border: 2px solid var(--color-text);
  }

  .cta-button.primary:hover {
    background-color: transparent;
    color: var(--color-text);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .cta-button.secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  .cta-button.secondary:hover {
    background-color: var(--color-border);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  /* ========================================
     Responsive Design
     ======================================== */

  @media (max-width: 768px) {
    .hero {
      min-height: 60vh;
    }

    .hero-title {
      font-size: var(--font-size-4xl);
    }

    .hero-subtitle {
      font-size: var(--font-size-xl);
    }

    .hero-description {
      font-size: var(--font-size-base);
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-button {
      width: 100%;
    }
  }

  /* ========================================
     Accessibility - Reduced Motion Override
     ======================================== */

  @media (prefers-reduced-motion: reduce) {
    .hero,
    .project-card {
      animation: none;
      opacity: 1;
    }

    .project-card:hover {
      transform: none;
    }

    .project-card:hover .card-image img {
      transform: none;
    }
  }
</style>
