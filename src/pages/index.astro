---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import OrbitalHero from '../components/OrbitalHero.astro';
---

<PortfolioLayout
  title="Home"
  description="Vincent Vidaurri - Product Manager & Designer specializing in aerospace, XR, and immersive technologies"
>
  <!-- Orbital Hero Section -->
  <OrbitalHero />

  <!-- Brief Bio Section -->
  <section class="bio">
    <h2 class="section-title">About Me</h2>
    <div class="bio-content">
      <p>
        With a background spanning NASA's cutting-edge research initiatives and Blue Origin's
        commercial spaceflight programs, I bring a unique perspective to product design and management.
        My expertise lies in translating complex technical requirements into intuitive, user-centered experiences.
      </p>
      <p>
        I specialize in AR/VR/XR technologies, design systems, and building products that blend
        hardware and software seamlessly. Whether it's developing IoT sensor networks for research
        facilities or creating AI-powered analysis tools, I'm driven by the challenge of solving
        meaningful problems through thoughtful design and engineering.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="cta-buttons">
      <a href="/projects" class="cta-button primary">View All Projects</a>
      <a href="/contact" class="cta-button secondary">Get in Touch</a>
    </div>
  </section>
</PortfolioLayout>

<style>
  /* ========================================
     Bio Section
     ======================================== */

  .section-title {
    font-family: var(--font-family-display);
    font-size: var(--font-size-3xl);
    font-weight: 600;
    margin-bottom: var(--spacing-2xl);
    color: var(--color-text);
  }

  .bio {
    margin-bottom: var(--spacing-3xl);
  }

  .bio-content {
    max-width: 800px;
  }

  .bio-content p {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }

  /* ========================================
     CTA Section
     ======================================== */

  .cta {
    margin-bottom: var(--spacing-3xl);
    padding: var(--spacing-3xl) 0;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md) var(--spacing-2xl);
    font-size: var(--font-size-lg);
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .cta-button.primary {
    background-color: var(--color-brand);
    color: var(--color-bg);
    border: 2px solid var(--color-brand);
    box-shadow: 0 0 20px rgba(65, 196, 66, 0.3);
  }

  .cta-button.primary:hover {
    background-color: transparent;
    color: var(--color-brand);
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(65, 196, 66, 0.5), var(--shadow-md);
  }

  .cta-button.secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  .cta-button.secondary:hover {
    background-color: rgba(65, 196, 66, 0.1);
    border-color: var(--color-brand);
    color: var(--color-brand);
    transform: translateY(-2px);
    box-shadow: 0 0 15px rgba(65, 196, 66, 0.2);
  }

  /* ========================================
     Responsive Design
     ======================================== */

  @media (max-width: 768px) {
    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-button {
      width: 100%;
    }
  }
</style>
