---
// No props — entries are discovered client-side via data-* attributes
---

<nav class="exp-timeline" aria-label="Experience timeline">
  <div class="exp-timeline-label">
    <span class="exp-timeline-label-text">Timeline</span>
    <div class="exp-timeline-label-line"></div>
  </div>
  <ol class="exp-timeline-list" id="exp-timeline-list"></ol>
</nav>

<script>
  function initTimeline() {
    const list = document.getElementById('exp-timeline-list');
    if (!list) return;

    // Discover all experience entries in document order
    const entries = Array.from(
      document.querySelectorAll<HTMLElement>('article[data-experience-period]')
    );
    if (entries.length === 0) return;

    // Clear any previously rendered items (e.g. after view transitions)
    list.innerHTML = '';

    // Build nav items and a map for active tracking
    const linkMap = new Map<string, HTMLAnchorElement>();

    entries.forEach((article) => {
      const id = article.id;
      const period = article.dataset.experiencePeriod ?? '';

      const li = document.createElement('li');
      li.className = 'exp-timeline-item';

      const a = document.createElement('a');
      a.href = `#${id}`;
      a.className = 'exp-timeline-link';
      a.dataset.entryId = id;

      a.textContent = period;
      li.appendChild(a);
      list.appendChild(li);

      linkMap.set(id, a);
    });

    // Active state management
    const visibleSet = new Set<string>();

    function setActive(id: string | null) {
      linkMap.forEach((a) => a.classList.remove('exp-timeline-link--active'));
      if (id && linkMap.has(id)) {
        linkMap.get(id)!.classList.add('exp-timeline-link--active');
      }
    }

    function pickActive() {
      // Primary: find the topmost entry currently in the intersection zone
      for (const article of entries) {
        if (visibleSet.has(article.id)) {
          setActive(article.id);
          return;
        }
      }
      // Fallback: when scrolling through the gap between tall cards, nothing
      // intersects the narrow zone. Find the last entry whose top has already
      // passed 30% of the viewport (i.e. the entry we're most recently inside).
      const threshold = window.innerHeight * 0.3;
      let fallback: HTMLElement | null = null;
      for (const article of entries) {
        if (article.getBoundingClientRect().top <= threshold) {
          fallback = article;
        } else {
          break;
        }
      }
      if (fallback) setActive(fallback.id);
    }

    const observer = new IntersectionObserver(
      (observerEntries) => {
        observerEntries.forEach((entry) => {
          if (entry.isIntersecting) {
            visibleSet.add(entry.target.id);
          } else {
            visibleSet.delete(entry.target.id);
          }
        });
        pickActive();
      },
      { rootMargin: '-10% 0px -80% 0px' }
    );

    entries.forEach((el) => observer.observe(el));

    // Set initial active from hash or first entry
    const hash = window.location.hash.slice(1);
    if (hash && linkMap.has(hash)) {
      setActive(hash);
    } else if (entries.length > 0) {
      setActive(entries[0].id);
    }
  }

  initTimeline();
  document.addEventListener('astro:after-swap', initTimeline);
</script>

<style>
  .exp-timeline {
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    scrollbar-width: none;
  }

  .exp-timeline::-webkit-scrollbar {
    display: none;
  }

  /* Label — matches toc-label and section-label patterns */
  .exp-timeline-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .exp-timeline-label-text {
    font-family: 'Courier New', monospace;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    font-weight: 600;
    white-space: nowrap;
  }

  .exp-timeline-label-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(65, 196, 66, 0.5), transparent);
  }

  /* List */
  .exp-timeline-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.exp-timeline-item) {
    margin: 0;
  }

  /* Links */
  :global(.exp-timeline-link) {
    display: block;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    text-decoration: none;
    line-height: 1.4;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  :global(.exp-timeline-link:hover) {
    color: var(--color-brand);
    border-left-color: rgba(65, 196, 66, 0.4);
    background-color: rgba(65, 196, 66, 0.05);
  }

  :global(.exp-timeline-link--active) {
    color: var(--color-text);
    border-left-color: var(--color-brand);
    background-color: rgba(65, 196, 66, 0.08);
  }
</style>
