---
// Navigation.astro
// Portfolio navigation component

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

// Navigation structure
const navigation = {
  sections: [
    {
      heading: 'Projects',
      href: '/projects',
      items: [
        { name: 'Stitch Out', href: '/projects/stitch-out' },
        { name: 'Figma Components', href: '/projects/figma' }
      ]
    }
  ],
  bottomLinks: [
    { name: 'Work History', href: '/resume' },
    { name: 'Contact', href: '/contact' }
  ]
};

// Helper to check if link is active
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');

// Helper to check if a section heading is active (exact match only, not children)
const isSectionActive = (section: typeof navigation.sections[0]) => {
  return currentPath === section.href;
};
---

<nav class="portfolio-nav">
  <!-- Logo -->
  <a href="/" class="logo-wrapper">
    <div class="logo">
      <img src="/images/logo/logo.svg" alt="Vincent Vidaurri Logo" class="logo-image" />
    </div>
  </a>

  <!-- Navigation Sections -->
  <div class="nav-content">
    <!-- Sections (Projects, etc.) -->
    {navigation.sections.map((section) => (
      <section class="nav-section">
        <a
          href={section.href}
          class:list={['nav-heading', { active: isSectionActive(section) }]}
        >
          {section.heading}
        </a>
        <ul class="nav-list">
          {section.items.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', 'nav-sublink', { active: isActive(item.href) }]}
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <!-- Bottom Links -->
    <div class="bottom-links">
      {navigation.bottomLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: isActive(link.href) }]}
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .portfolio-nav {
    display: flex;
    flex-direction: column;
    gap: 40px;
    width: 155px;
    padding: 10px;
    position: relative;
  }

  /* Logo Styles */
  .logo-wrapper {
    display: block;
    width: 100%;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .logo-wrapper:hover {
    transform: scale(1.05);
  }

  .logo {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
  }

  .logo-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Navigation Content */
  .nav-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
    flex: 1;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  /* Section heading (clickable) */
  .nav-heading {
    font-family: 'Roboto', sans-serif;
    font-size: 18px;
    font-weight: 400;
    text-decoration: none;
    display: block;
    color: var(--color-text-secondary);
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: var(--spacing-xs) var(--spacing-sm);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-heading:hover {
    color: var(--color-brand);
    border-left-color: var(--color-brand-glow);
    background-color: rgba(65, 196, 66, 0.05);
    transform: translateX(2px);
  }

  .nav-heading.active {
    color: var(--color-text);
    border-left-color: var(--color-brand);
    background-color: rgba(65, 196, 66, 0.08);
    box-shadow: inset 2px 0 6px rgba(65, 196, 66, 0.25);
    transform: none;
  }

  .nav-link {
    font-family: 'Roboto', sans-serif;
    font-size: 18px;
    font-weight: 400;
    text-decoration: none;
    display: block;
    position: relative;
    color: var(--color-text-secondary);
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: var(--spacing-xs) var(--spacing-sm);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-brand);
    border-left-color: var(--color-brand-glow);
    background-color: rgba(65, 196, 66, 0.05);
    transform: translateX(2px);
  }

  .nav-link.active {
    color: var(--color-text);
    border-left-color: var(--color-brand);
    background-color: rgba(65, 196, 66, 0.08);
    box-shadow: inset 2px 0 6px rgba(65, 196, 66, 0.25);
    transform: none;
  }

  /* Sub-item specific styles */
  .nav-sublink {
    font-size: 16px;
    padding-left: calc(var(--spacing-sm) + 10px);
  }

  .nav-sublink:hover {
    transform: none;
  }

  .bottom-links {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .portfolio-nav {
      width: 100%;
      max-width: 155px;
      gap: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-heading,
    .nav-link {
      transition: none;
    }

    .nav-heading:hover,
    .nav-link:hover {
      transform: none;
    }
  }
</style>
