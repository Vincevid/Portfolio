---
interface Props {
  role: string;
  company: string;
  period: string;
  location: string;
  tags: string[];
}

const { role, company, period, location, tags } = Astro.props;

const entryId = [company, period]
  .join('-')
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-|-$/g, '');
---

<article
  class="experience-entry"
  id={entryId}
  data-experience-period={period}
  data-experience-company={company}
>
  <div class="entry-label">
    <span class="label-text">{company}</span>
    <div class="label-line"></div>
  </div>

  <h3 class="entry-role">{role}</h3>

  <div class="entry-meta">
    <span class="entry-period">{period}</span>
    <span aria-hidden="true">·</span>
    <span class="entry-location">{location}</span>
  </div>

  <div class="entry-tags">
    {tags.map(tag => <span class="entry-tag">{tag}</span>)}
  </div>

  <div class="entry-body">
    <slot />
  </div>
</article>

<style>
  .experience-entry {
    background: linear-gradient(135deg, rgba(45, 45, 45, 0.4), rgba(35, 35, 35, 0.6));
    border: 1px solid rgba(65, 196, 66, 0.15);
    border-left: 3px solid var(--color-brand);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
    overflow: hidden;
    position: relative;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .experience-entry::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-brand), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .experience-entry:hover {
    transform: translateY(-2px);
    border-color: rgba(65, 196, 66, 0.4);
    box-shadow: 0 8px 24px rgba(65, 196, 66, 0.15);
  }

  .experience-entry:hover::before {
    opacity: 1;
  }

  /* Section label */
  .entry-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .label-text {
    font-family: 'Courier New', monospace;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    font-weight: 600;
    white-space: nowrap;
  }

  .label-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(65, 196, 66, 0.5), transparent);
  }

  /* Role heading */
  .entry-role {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  /* Period · Location */
  .entry-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .entry-period,
  .entry-location {
    color: var(--color-text-muted);
  }

  /* Tag chips */
  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .entry-tag {
    background-color: rgba(45, 45, 45, 0.8);
    backdrop-filter: blur(10px);
    color: var(--color-text-secondary);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    border: 1px solid rgba(65, 196, 66, 0.2);
    transition: all var(--transition-fast);
  }

  .entry-tag:hover {
    border-color: rgba(65, 196, 66, 0.5);
    color: var(--color-brand);
  }

  /* Slot content — must use :global to reach slotted paragraphs */
  .entry-body :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-md);
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .experience-entry,
    .experience-entry::before {
      transition: none;
    }
  }
</style>
